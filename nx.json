{
  "affected": {
    "defaultBase": "origin/main"
  },
  "namedInputs": {
    "default": [
      "sharedGlobals",
      "{projectRoot}/**/*"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/babel.config.json"
    ],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/eslint.config.mjs"
    ]
  },
  "targetDefaults": {
    "test": {
      "options": {
        "passWithNoTests": true,
        "cache": true
      }
    },
    "lint": {
      "options": {
        "cache": true,
        "cache-strategy": "content"
      },
      "configurations": {
        "ci": {
          "cache-location": "$HOME/.eslint/"
        }
      }
    },
    "build-lib": {
      "options": {
        "args": [
          "--verbose"
        ]
      }
    },
    "typecheck": {
      "options": {
        "args": [
          "tsconfig.lib.json",
          "--verbose"
        ]
      }
    }
  },
  "plugins": [
    "@nx/eslint/plugin",
    "@nx/jest/plugin",
    "@nx/next/plugin",
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "compiler": "tsgo",
        "build": {
          "compiler": "tsgo",
          "targetName": "build-lib",
          "configName": "tsconfig.lib.json"
        }
      },
      "include": [
        "libs/**/*"
      ],
      "exclude": [
        "apps/**/*",
        "apps/*-e2e/**/*"
      ]
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    }
  ],
  "analytics": false,
  "cache": 234
}